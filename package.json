{
  "name": "paws-animal-shelter",
  "version": "1.0.0",
  "description": "Paws Animal Shelter Management Platform",
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --prefix backend",
    "app:dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "frontend:dev": "npm run dev --prefix frontend",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest --coverage"
  },
  "keywords": [
    "animal-shelter",
    "adoption",
    "donation",
    "management-platform"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "jest": "^30.2.0",
    "supertest": "^7.1.4"
  }
}
